{
  "manifest_version": 3,
  "name": "Comfy Assistant Builder",
  "version": "0.1.0",
  "description": "Assistant panel for building ComfyUI workflows from natural language.",
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1:8188/*",
    "http://localhost:8188/*",
    "http://127.0.0.1:8797/*",
    "http://localhost:8797/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1:8188/*",
        "http://localhost:8188/*"
      ],
      "js": ["cab_config.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page_bridge.js"],
      "matches": ["http://127.0.0.1:8188/*", "http://localhost:8188/*"]
    }
  ]
}
